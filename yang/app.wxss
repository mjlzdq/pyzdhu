/* app.wxss - 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

view, text, image, button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
}

button::after {
  border: none;
}
