/* pages/game/game.wxss */
page {
  background: linear-gradient(180deg, #2D8A3E 0%, #1B6E2C 25%, #155D24 50%, #0F4D1E 80%, #0A3D18 100%);
  min-height: 100vh;
  overflow-x: hidden;
}

.game-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
  position: relative;
  overflow: hidden;
}

/* ========== 背景装饰 ========== */
.game-container::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 30% 10%, rgba(255,255,255,0.07) 0%, transparent 45%),
    radial-gradient(ellipse at 70% 70%, rgba(0,0,0,0.08) 0%, transparent 40%),
    radial-gradient(circle at 15% 85%, rgba(76,175,80,0.06) 0%, transparent 35%);
  pointer-events: none;
  z-index: 0;
}

/* ========== 顶部导航栏（美化） ========== */
.top-bar {
  flex: 0 0 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
  z-index: 5;
}
.top-left, .top-right {
  width: 120rpx;
  display: flex;
  align-items: center;
}
.top-right { justify-content: flex-end; }
.back-btn {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  font-size: 25rpx;
  color: rgba(255,255,255,0.94);
  padding: 12rpx 28rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.1));
  border-radius: 40rpx;
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  transition: all 0.2s;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: 1.5rpx solid rgba(255,255,255,0.15);
  box-sizing: border-box;
  box-shadow: 0 3rpx 10rpx rgba(0,0,0,0.08);
}
.back-btn:active {
  background: rgba(255,255,255,0.26);
  transform: scale(0.95);
}

/* ========== 得分/步数信息区（美化） ========== */
.top-center {
  display: flex;
  gap: 28rpx;
}
.score-area, .steps-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.22), rgba(0,0,0,0.12));
  padding: 10rpx 30rpx 8rpx;
  border-radius: 22rpx;
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1.5rpx solid rgba(255,255,255,0.08);
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.06), 0 3rpx 12rpx rgba(0,0,0,0.05);
}
.score-label, .steps-label {
  font-size: 17rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 4rpx;
}
.score-value, .steps-value {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.35);
  font-variant-numeric: tabular-nums;
}

/* ========== 关卡徽章（闯关模式专用） ========== */
.level-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(180deg, rgba(255,193,7,0.25), rgba(255,152,0,0.18));
  padding: 8rpx 22rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  border: 1.5rpx solid rgba(255,193,7,0.35);
  box-shadow: inset 0 1.5rpx 3rpx rgba(255,235,59,0.12), 0 3rpx 12rpx rgba(255,152,0,0.08);
}
.level-label {
  font-size: 18rpx;
  color: rgba(255,235,59,0.85);
  font-weight: 600;
}
.level-value {
  font-size: 36rpx;
  font-weight: 900;
  color: #FFD54F;
  text-shadow: 0 2rpx 8rpx rgba(255,152,0,0.35);
  font-variant-numeric: tabular-nums;
}

/* ========== 游戏卡片区（上移留足空间） ========== */
.game-board {
  flex: 1;
  position: relative;
  margin: 8rpx 16rpx 6rpx;
  min-height: 280rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, rgba(0,0,0,0.04) 100%);
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 2;
  box-shadow:
    inset 0 0 40rpx rgba(0,0,0,0.05),
    0 4rpx 20rpx rgba(0,0,0,0.08);
  border: 1.5rpx solid rgba(255,255,255,0.08);
}

.card {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: linear-gradient(160deg, #FFFFFF 0%, #F9FAFB 35%, #EDF0F2 100%);
  border: 2rpx solid rgba(129,199,132,0.4);
  border-bottom-width: 7rpx;
  border-bottom-color: rgba(102,187,106,0.75);
  box-shadow:
    0 6rpx 18rpx rgba(0,0,0,0.12),
    0 2rpx 5rpx rgba(0,0,0,0.05),
    inset 0 2.5rpx 0 rgba(255,255,255,0.95),
    inset 0 -1.5rpx 3rpx rgba(0,0,0,0.02);
  font-weight: 700;
  color: #37474F;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
  user-select: none;
}

.card.blocked {
  background: linear-gradient(160deg, #C8E6C9 0%, #A8D6A9 50%, #94C995 100%);
  border-color: rgba(129,199,132,0.55);
  border-bottom-color: rgba(76,175,80,0.85);
  color: rgba(56,71,79,0.28);
  box-shadow:
    0 3rpx 8rpx rgba(0,0,0,0.07),
    inset 0 2rpx 0 rgba(255,255,255,0.45);
}

.card:not(.blocked) {
  cursor: pointer;
}

.card:not(.blocked):active {
  transform: scale(0.90) translateY(3rpx);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
  border-bottom-width: 3rpx;
  border-bottom-color: rgba(76,175,80,0.92);
}

.card.hint {
  animation: hintGlow 0.5s ease-in-out infinite alternate;
  border-color: #FFCA28 !important;
  border-bottom-color: #FF8F00 !important;
  box-shadow: 0 0 16rpx rgba(255,202,40,0.5), 0 4rpx 12rpx rgba(0,0,0,0.1) !important;
}

@keyframes hintGlow {
  from {
    box-shadow: 0 0 12rpx rgba(255,193,7,0.35), 0 4rpx 12rpx rgba(0,0,0,0.1);
    transform: scale(1);
  }
  to {
    box-shadow: 0 0 28rpx rgba(255,193,7,0.65), 0 4rpx 16rpx rgba(0,0,0,0.14);
    transform: scale(1.03);
  }
}

/* ========== 槽位区（正常大小，固定高度） ========== */
.slot-area {
  flex: 0 0 120rpx;
  padding: 8rpx 28rpx;
  display: flex;
  align-items: center;
  position: relative;
  z-index: 3;
  overflow: visible;
}
.slot-row {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  width: 100%;
  padding: 4rpx 6rpx;
  position: relative;
}
.slot-box {
  width: 78rpx;
  height: 78rpx;
  border: none;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.07);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 1;
  box-shadow: inset 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.slot-box.filled {
  color: #1B5E20;
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7F5 100%);
  box-shadow:
    0 4rpx 16rpx rgba(0,0,0,0.12),
    0 1rpx 4rpx rgba(0,0,0,0.04),
    inset 0 1rpx 0 rgba(255,255,255,0.9);
  border: 1.5rpx solid rgba(200,230,201,0.6);
}
.slot-box.danger {
  color: #fff !important;
  background: rgba(244,67,54,0.65) !important;
  border: 1.5rpx solid rgba(244,67,54,0.5) !important;
  box-shadow: 0 0 20rpx rgba(244,67,54,0.45) !important;
  animation: dangerShake 0.35s ease;
}

@keyframes dangerShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-7rpx); }
  40% { transform: translateX(7rpx); }
  60% { transform: translateX(-5rpx); }
  80% { transform: translateX(5rpx); }
}

/* ========== 道具栏（放大美化，固定高度） ========== */
.tools-bar {
  flex: 0 0 110rpx;
  display: flex;
  gap: 12rpx;
  padding: 4rpx 16rpx;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 3;
}
.tool-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.97), rgba(250,252,249,0.95));
  border: 1.5rpx solid rgba(200,230,201,0.55);
  border-radius: 22rpx;
  padding: 14rpx 18rpx;
  min-width: 126rpx;
  color: #1B5E20;
  transition: all 0.18s ease;
  box-shadow:
    0 4rpx 14rpx rgba(0,0,0,0.09),
    inset 0 2rpx 0 rgba(255,255,255,0.92);
}
.tool-btn:active {
  background: #fff;
  transform: scale(0.94) translateY(2rpx);
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.tool-btn.empty {
  opacity: 0.65;
  filter: grayscale(0.5);
}
.tool-btn.tool-get {
  border-color: rgba(67,160,71,0.45);
  border-style: dashed;
  background: rgba(255,255,255,0.72);
}
.tool-btn.tool-get:active {
  background: rgba(232,245,233,0.9);
  transform: scale(0.94) translateY(2rpx);
}
.tool-icon {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
}
.tool-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  line-height: 1.2;
}
.tool-name {
  font-size: 18rpx;
  color: #2E7D32;
  font-weight: 700;
}
.tool-count {
  font-size: 22rpx;
  font-weight: 900;
  color: #E65100;
  text-shadow: 0 1rpx 0 rgba(255,152,0,0.15);
}
.tool-get .tool-count {
  color: #2E7D32;
  font-weight: 700;
}

/* ========== 广告弹窗 ========== */
.ad-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.25s ease;
}
.ad-modal {
  width: 580rpx;
  background: linear-gradient(180deg, #FFF 0%, #FAFAFA 100%);
  border-radius: 36rpx;
  padding: 52rpx 44rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow:
    0 24rpx 80rpx rgba(0,0,0,0.3),
    0 8rpx 24rpx rgba(0,0,0,0.12);
  animation: slideUp 0.35s cubic-bezier(0.34,1.56,0.64,1);
  border: 1rpx solid rgba(255,255,255,0.6);
}
.ad-modal-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0,0,0,0.1));
}
.ad-modal-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1B5E20;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
}
.ad-modal-desc {
  font-size: 26rpx;
  color: #777;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 32rpx;
}
.ad-modal-btn {
  width: 420rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(180deg, #FFB74D, #FF9800, #F57C00);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  box-shadow:
    0 8rpx 28rpx rgba(255,152,0,0.4),
    inset 0 2rpx 0 rgba(255,255,255,0.2);
  margin-bottom: 18rpx;
  transition: all 0.18s;
  letter-spacing: 2rpx;
}
.ad-modal-btn:active {
  transform: scale(0.95) translateY(2rpx);
  box-shadow: 0 4rpx 14rpx rgba(255,152,0,0.28);
}
.ad-modal-cancel {
  font-size: 26rpx;
  color: #AAA;
  padding: 10rpx 24rpx;
  font-weight: 500;
}

/* ========== 游戏结束弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}
.modal-box {
  width: 600rpx;
  background: linear-gradient(180deg, #FFF 0%, #FCFCFC 100%);
  border-radius: 40rpx;
  padding: 56rpx 48rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow:
    0 28rpx 88rpx rgba(0,0,0,0.35),
    0 8rpx 24rpx rgba(0,0,0,0.12);
  animation: slideUp 0.4s cubic-bezier(0.34,1.56,0.64,1);
  border: 1rpx solid rgba(255,255,255,0.6);
}
.modal-emoji {
  font-size: 96rpx;
  margin-bottom: 12rpx;
  animation: bounceIn 0.6s cubic-bezier(0.34,1.56,0.64,1);
  filter: drop-shadow(0 6rpx 16rpx rgba(0,0,0,0.12));
}
.modal-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #1B5E20;
  margin-bottom: 18rpx;
  letter-spacing: 3rpx;
}
.modal-score {
  font-size: 58rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #FF9800, #F57C00, #E65100);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(255,152,0,0.15));
}
.modal-steps {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  font-weight: 500;
}
.modal-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}
.modal-btn {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 48rpx;
  font-size: 31rpx;
  font-weight: 700;
  border: none;
  color: #fff;
  transition: all 0.18s;
  letter-spacing: 2rpx;
}
.modal-btn.primary {
  background: linear-gradient(180deg, #FFB74D, #FF9800, #F57C00);
  box-shadow: 0 8rpx 28rpx rgba(255,152,0,0.4), inset 0 2rpx 0 rgba(255,255,255,0.2);
}
.modal-btn.primary:active {
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 0 4rpx 14rpx rgba(255,152,0,0.25);
}
.modal-btn.next {
  background: linear-gradient(180deg, #66BB6A, #43A047, #2E7D32);
  box-shadow: 0 8rpx 28rpx rgba(67,160,71,0.35), inset 0 2rpx 0 rgba(255,255,255,0.18);
}
.modal-btn.next:active {
  transform: scale(0.96) translateY(2rpx);
  box-shadow: 0 4rpx 14rpx rgba(67,160,71,0.2);
}
.modal-btn.secondary {
  background: linear-gradient(180deg, #F0F0F0, #EBEBEB);
  color: #888;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06), inset 0 1rpx 0 rgba(255,255,255,0.5);
}
.modal-btn.secondary:active {
  transform: scale(0.96) translateY(2rpx);
  background: #E0E0E0;
}

/* ========== 动画 ========== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(80rpx) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.25); }
  70% { transform: scale(0.92); }
  100% { transform: scale(1); opacity: 1; }
}

/* ========== 底部原生模板广告（固定高度） ========== */
.bottom-ad-wrap {
  flex: 0 0 90rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 0 20rpx env(safe-area-inset-bottom);
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}
.bottom-ad-wrap ad-custom {
  width: 100%;
  max-height: 90rpx;
  display: block;
}

/* ========== Toast ========== */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.78);
  backdrop-filter: blur(12rpx);
  color: #fff;
  font-size: 28rpx;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  z-index: 999;
  pointer-events: none;
  font-weight: 500;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);
  animation: toastIn 0.28s cubic-bezier(0.34,1.56,0.64,1);
}

@keyframes toastIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.82);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}
