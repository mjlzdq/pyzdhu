<!-- pages/index/index.wxml -->
<view class="home-container">
  <!-- 顶部标题区 -->
  <view class="header-area">
    <button class="header-logo-wrap" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="header-logo" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}"></image>
      <text class="header-logo-placeholder" wx:else>🐑</text>
    </button>
    <view class="header-title">合就完了</view>
  </view>

  <!-- 右上角按钮组 -->
  <view class="corner-btns">
    <!-- 礼包入口 -->
    <view class="corner-fab corner-gift" bindtap="openGiftPanel">
      <text class="corner-fab-icon">🎁</text>
    </view>
    <!-- 排行榜按钮 -->
    <view class="corner-fab corner-rank" bindtap="openRanking">
      <text class="corner-fab-icon">🏅</text>
    </view>
    <!-- 设置按钮 -->
    <view class="corner-fab corner-settings" bindtap="openSettings">
      <text class="corner-fab-icon">⚙️</text>
    </view>
  </view>

  <!-- 新人礼包弹窗 -->
  <view class="gift-mask" wx:if="{{showNewPlayerGift}}" catchtouchmove="noop">
    <view class="gift-modal">
      <view class="gift-emoji">🎁</view>
      <view class="gift-title">🎉 新人礼包</view>
      <view class="gift-desc">欢迎来到合就完了！送你一份见面礼：</view>
      <view class="gift-list">
        <view class="gift-item">↩️ 撤回 ×3</view>
        <view class="gift-item">🔀 洗牌 ×3</view>
        <view class="gift-item">➕ 加槽 ×3</view>
        <view class="gift-item">💡 提示 ×3</view>
      </view>
      <view class="gift-tip">仅限新人领取一次</view>
      <button class="gift-btn" bindtap="claimGift">🎁 立即领取</button>
      <view class="gift-skip" bindtap="skipGift">残忍拒绝</view>
    </view>
  </view>

  <!-- 统计行 -->
  <view class="top-row" wx:if="{{!showNewPlayerGift}}">
    <view class="stats-bar stats-bar-full">
      <view class="stat-item">
        <text class="stat-val">{{gameData.highScore}}</text>
        <text class="stat-lbl">最高分</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-val">{{gameData.totalGames}}</text>
        <text class="stat-lbl">总局数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-val">{{gameData.totalWins}}</text>
        <text class="stat-lbl">总通关</text>
      </view>
    </view>
  </view>

  <!-- 积分卡片 -->
  <view class="points-section">
    <view class="points-card">
      <view class="points-left">
        <text class="points-icon">🪙</text>
        <text class="points-value">{{points}}</text>
      </view>
      <view class="points-right">
        <text class="points-label">积分</text>
      </view>
    </view>
  </view>

  <!-- 模式列表 - 平铺式 -->
  <view class="mode-list">
    <!-- 简单模式 -->
    <view class="mode-item mode-item-easy" bindtap="startEasy">
      <view class="mode-item-left">
        <view class="mode-item-icon">🌱</view>
        <view class="mode-item-text">
          <view class="mode-item-name">简单模式</view>
          <view class="mode-item-info">已通关 {{gameData.easyWins}} 次</view>
        </view>
      </view>
      <view class="mode-item-right">
        <view class="mode-item-helper" catchtap="noop">
          <text>?</text>
          <view class="mode-item-tooltip">3层 · 8槽位</view>
        </view>
        <view class="mode-item-arrow">›</view>
      </view>
    </view>

    <!-- 噩梦模式 -->
    <view class="mode-item mode-item-nightmare" bindtap="startNightmare">
      <view class="mode-item-left">
        <view class="mode-item-icon">💀</view>
        <view class="mode-item-text">
          <view class="mode-item-name">噩梦试炼</view>
          <view class="mode-item-info">已通关 {{gameData.nightmareWins}} 次</view>
        </view>
      </view>
      <view class="mode-item-right">
        <view class="mode-item-helper" catchtap="noop">
          <text>?</text>
          <view class="mode-item-tooltip">8层 · 6槽位</view>
        </view>
        <view class="mode-item-arrow">›</view>
      </view>
    </view>

    <!-- 闯关模式 -->
    <view class="mode-item mode-item-challenge" bindtap="startChallenge">
      <view class="mode-item-left">
        <view class="mode-item-icon">🏆</view>
        <view class="mode-item-text">
          <view class="mode-item-name">闯关模式</view>
          <view class="mode-item-info">最高 {{gameData.challengeMaxLevel}} 层</view>
        </view>
      </view>
      <view class="mode-item-right">
        <view class="mode-item-helper" catchtap="noop">
          <text>?</text>
          <view class="mode-item-tooltip">最高9999层</view>
        </view>
        <view class="mode-item-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 闯关排行（全屏展开） -->
  <view class="ranking-overlay" wx:if="{{showRanking}}" catchtouchmove="noop">
    <view class="ranking-fullscreen">
      <!-- 顶部关闭栏 -->
      <view class="ranking-top-bar">
        <view class="ranking-top-left">
          <view class="ranking-top-title">🏅 闯关排行榜</view>
          <view class="ranking-top-desc">前10名 · 仅统计闯关模式</view>
        </view>
        <view class="ranking-top-close" bindtap="closeRanking">✕</view>
      </view>
      <!-- 前三名领奖台 -->
      <view class="ranking-podium" wx:if="{{gameData.rankings && gameData.rankings.length >= 3}}">
        <view class="podium-item podium-2">
          <view class="podium-avatar">🥈</view>
          <view class="podium-name">{{gameData.rankings[1].name}}</view>
          <view class="podium-score">{{gameData.rankings[1].maxLevel}} 层</view>
          <view class="podium-bar podium-bar-2"></view>
        </view>
        <view class="podium-item podium-1">
          <view class="podium-avatar">👑</view>
          <view class="podium-name">{{gameData.rankings[0].name}}</view>
          <view class="podium-score">{{gameData.rankings[0].maxLevel}} 层</view>
          <view class="podium-bar podium-bar-1"></view>
        </view>
        <view class="podium-item podium-3">
          <view class="podium-avatar">🥉</view>
          <view class="podium-name">{{gameData.rankings[2].name}}</view>
          <view class="podium-score">{{gameData.rankings[2].maxLevel}} 层</view>
          <view class="podium-bar podium-bar-3"></view>
        </view>
      </view>
      <!-- 榜单列表（不足3人时显示全部，否则从第4名开始） -->
      <scroll-view class="ranking-list" scroll-y>
        <view class="ranking-item {{item.isSelf ? 'ranking-self' : ''}}" wx:for="{{gameData.rankings}}" wx:key="name" wx:if="{{gameData.rankings.length < 3 || index >= 3}}">
          <view class="ranking-left">
            <text class="ranking-rank rank-normal">{{index + 1}}</text>
            <text class="ranking-name">{{item.name}}</text>
            <text class="ranking-self-tag" wx:if="{{item.isSelf}}">我</text>
          </view>
          <text class="ranking-level {{item.maxLevel >= 9999 ? 'max-level' : ''}}">{{item.maxLevel}} 层</text>
        </view>
        <view wx:if="{{!gameData.rankings || gameData.rankings.length === 0}}" class="ranking-empty">暂无排行，快来挑战闯关模式吧！</view>
      </scroll-view>
    </view>
  </view>

  <!-- 礼包弹窗 -->
  <view class="panel-mask" wx:if="{{showGiftPanel}}" catchtouchmove="noop" bindtap="closeGiftPanel">
    <view class="panel-modal panel-gift-modal" catchtap="noop">
      <!-- 头部装饰 -->
      <view class="gift-panel-header">
        <view class="gift-panel-decor">
          <text class="gift-panel-decor-icon">🎁</text>
        </view>
        <view class="gift-panel-title">获取积分</view>
        <view class="gift-panel-subtitle">多种方式轻松赚积分</view>
        <view class="panel-close panel-close-abs" bindtap="closeGiftPanel">✕</view>
      </view>
      <!-- 积分概览卡片 -->
      <view class="gift-points-banner">
        <text class="gift-points-icon">🪙</text>
        <view class="gift-points-info">
          <text class="gift-points-label">当前积分</text>
          <text class="gift-points-num">{{points}}</text>
        </view>
      </view>
      <!-- 签到卡片 -->
      <view class="gift-card {{signData.signedToday && signData.signAdWatched ? 'gift-card-done' : ''}}">
        <view class="gift-card-bg">
          <text class="gift-card-decor-l">✨</text>
          <text class="gift-card-decor-r">✨</text>
        </view>
        <view class="gift-card-content">
          <view class="gift-card-icon-wrap">
            <text class="gift-card-icon">{{signData.signedToday && signData.signAdWatched ? '✅' : '📅'}}</text>
          </view>
          <view class="gift-card-body">
            <text class="gift-card-name">每日签到</text>
            <text class="gift-card-desc" wx:if="{{!signData.signedToday}}">直接领 20 积分，看广告得 40 积分+道具</text>
            <text class="gift-card-desc" wx:elif="{{!signData.signAdWatched}}">还可用看广告获得 20 积分+道具</text>
            <text class="gift-card-desc" wx:else>明天再来～</text>
          </view>
        </view>
        <!-- 两个按钮 -->
        <view class="gift-sign-btns">
          <button class="gift-sign-btn gift-sign-btn-basic {{signData.signedToday ? 'gift-btn-disabled' : ''}}" bindtap="onDailySignBasic">直接领 20 积分</button>
          <button class="gift-sign-btn gift-sign-btn-ad {{!signData.canWatchAd ? 'gift-btn-disabled' : ''}}" bindtap="onDailySignAd">{{signData.signedToday && !signData.signAdWatched ? '看广告补领 20积分+道具' : '看广告 40积分+道具'}}</button>
        </view>
      </view>
      <!-- 两个小卡片并排 -->
      <view class="gift-card-row">
        <!-- 邀请好友 -->
        <button class="gift-mini-card" open-type="share">
          <text class="gift-mini-icon">👥</text>
          <text class="gift-mini-name">邀请好友</text>
          <text class="gift-mini-desc">5~15 积分</text>
          <text class="gift-mini-arrow">→</text>
        </button>
        <!-- 观看视频 -->
        <view class="gift-mini-card" bindtap="earnPoints">
          <text class="gift-mini-icon">📺</text>
          <text class="gift-mini-name">观看视频</text>
          <text class="gift-mini-desc">+10 积分</text>
          <text class="gift-mini-arrow">→</text>
        </view>
      </view>
      <!-- 底部提示 -->
      <view class="gift-panel-footer">
        <text class="gift-footer-icon">💡</text>
        <text class="gift-footer-text">每天签到 + 邀请好友，积分攒不停～</text>
      </view>
    </view>
  </view>

  <!-- 设置弹窗 -->
  <view class="panel-mask" wx:if="{{showSettings}}" catchtouchmove="noop" bindtap="closeSettings">
    <view class="panel-modal panel-setting-modal" catchtap="noop">
      <!-- 头部 -->
      <view class="setting-panel-header">
        <view class="setting-panel-decor">
          <text class="setting-panel-decor-icon">⚙️</text>
        </view>
        <view class="setting-panel-title">设置</view>
        <view class="setting-panel-subtitle">管理你的游戏偏好</view>
        <view class="panel-close panel-close-abs" bindtap="closeSettings">✕</view>
      </view>
      <!-- 用户ID卡片 -->
      <view class="setting-user-card">
        <view class="setting-user-avatar">🐑</view>
        <view class="setting-user-info">
          <text class="setting-user-name">{{gameData.playerName}}</text>
          <text class="setting-user-id">ID: {{gameData.userId}}</text>
        </view>
        <view class="setting-user-copy" bindtap="copyUserId">
          <text class="setting-copy-icon">📋</text>
          <text class="setting-copy-text">复制</text>
        </view>
      </view>
      <!-- 设置列表 -->
      <view class="setting-section">
        <view class="setting-section-title">音效设置</view>
        <!-- 音乐开关 -->
        <view class="setting-item">
          <view class="setting-item-left">
            <view class="setting-item-icon-wrap music-icon-wrap">
              <text class="setting-item-icon">🎵</text>
            </view>
            <view class="setting-item-text">
              <text class="setting-item-name">背景音乐</text>
              <text class="setting-item-desc">{{gameData.settings.musicOn ? '已开启' : '已关闭'}}</text>
            </view>
          </view>
          <switch checked="{{gameData.settings.musicOn}}" bindchange="toggleMusic" color="#43A047"/>
        </view>
        <!-- 音效开关 -->
        <view class="setting-item">
          <view class="setting-item-left">
            <view class="setting-item-icon-wrap sound-icon-wrap">
              <text class="setting-item-icon">🔔</text>
            </view>
            <view class="setting-item-text">
              <text class="setting-item-name">游戏音效</text>
              <text class="setting-item-desc">{{gameData.settings.soundOn ? '已开启' : '已关闭'}}</text>
            </view>
          </view>
          <switch checked="{{gameData.settings.soundOn}}" bindchange="toggleSound" color="#43A047"/>
        </view>
      </view>
      <!-- 底部信息 -->
      <view class="setting-footer">
        <text class="setting-footer-text">合就完了 v1.0</text>
      </view>
    </view>
  </view>

  <!-- 积分不足弹窗 -->
  <view class="panel-mask" wx:if="{{showNoPointsModal}}" catchtouchmove="noop">
    <view class="panel-modal panel-nopoints-modal" catchtap="noop">
      <!-- 头部装饰 -->
      <view class="nopoints-header">
        <view class="nopoints-decor">
          <text class="nopoints-decor-icon">😢</text>
        </view>
        <view class="nopoints-title">积分不足</view>
        <view class="panel-close panel-close-abs" bindtap="closeNoPointsModal">✕</view>
      </view>
      <!-- 内容区 -->
      <view class="nopoints-body">
        <view class="nopoints-info-card">
          <view class="nopoints-mode-name">{{noPointsData.modeName}}</view>
          <view class="nopoints-cost-row">
            <text class="nopoints-cost-label">需要积分</text>
            <text class="nopoints-cost-value">{{noPointsData.cost}}</text>
          </view>
          <view class="nopoints-divider"></view>
          <view class="nopoints-current-row">
            <text class="nopoints-current-label">当前积分</text>
            <text class="nopoints-current-value">{{noPointsData.current}}</text>
          </view>
        </view>
        <view class="nopoints-tip">
          <text class="nopoints-tip-icon">💡</text>
          <text class="nopoints-tip-text">观看广告即可获得 +10 积分</text>
        </view>
      </view>
      <!-- 按钮区 -->
      <view class="nopoints-btns">
        <button class="nopoints-btn nopoints-btn-cancel" bindtap="closeNoPointsModal">取消</button>
        <button class="nopoints-btn nopoints-btn-confirm" bindtap="watchAdForPoints">
          <text class="nopoints-btn-icon">📺</text>
          看广告获取
        </button>
      </view>
    </view>
  </view>

</view>

<!-- 底部原生模板广告（fixed定位，不参与文档流） -->
<view class="bottom-ad-wrap">
  <ad-custom unit-id="adunit-3a4d661c81f6ed2f" bindload="adLoad" binderror="adError" bindclose="adClose"></ad-custom>
</view>
