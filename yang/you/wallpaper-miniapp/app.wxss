/* app.wxss - 全局样式 */
page {
  background-color: #0f0f23;
  color: #e0e0e0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #e94560);
  color: #fff;
  border: none;
  border-radius: 24px;
  padding: 14px 36px;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.btn-outline {
  background: transparent;
  color: #6c63ff;
  border: 2rpx solid #6c63ff;
  border-radius: 24px;
  padding: 12px 32px;
  font-size: 28rpx;
}

/* 加载中 */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  margin: 0 8rpx;
  border-radius: 50%;
  background: #6c63ff;
  animation: loading 1.2s ease-in-out infinite;
}

.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes loading {
  0%, 80%, 100% { transform: scale(0.4); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 广告容器 */
.banner-ad-container {
  width: 100%;
  padding: 10rpx 0;
  display: flex;
  justify-content: center;
  background: #1a1a2e;
}
