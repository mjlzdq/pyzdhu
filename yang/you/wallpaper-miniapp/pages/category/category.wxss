/* pages/category/category.wxss */
.container {
  padding-bottom: 20rpx;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 24rpx;
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 28rpx 10rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.category-card.active {
  border-color: #6c63ff;
  background: rgba(108, 99, 255, 0.1);
}

.category-icon {
  font-size: 52rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 6rpx;
}

.category-count {
  font-size: 20rpx;
  color: #666;
}

/* 分区标题 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx 16rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.title-count {
  font-size: 24rpx;
  color: #666;
}

/* 瀑布流 */
.waterfall {
  display: flex;
  padding: 0 16rpx;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wallpaper-card {
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a2e;
}

.wallpaper-card:active {
  transform: scale(0.97);
}

.wallpaper-img {
  width: 100%;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
}

.wallpaper-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 16rpx;
}

.wallpaper-tag {
  font-size: 22rpx;
  color: #6c63ff;
  background: rgba(108, 99, 255, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.like-count {
  font-size: 22rpx;
  color: #888;
}

.load-more {
  text-align: center;
  padding: 40rpx;
  color: #555;
  font-size: 24rpx;
}
