<!-- pages/detail/detail.wxml -->
<view class="container" wx:if="{{wallpaper}}">
  <!-- 大图预览 -->
  <view class="image-wrapper">
    <image class="preview-image" 
           src="{{wallpaper.url}}" 
           mode="widthFix" 
           show-menu-by-longpress="{{true}}">
    </image>
  </view>

  <!-- 图片信息 -->
  <view class="info-section">
    <view class="info-row">
      <text class="info-label">{{wallpaper.category}}</text>
      <view class="info-stats">
        <text class="stat-item">❤️ {{wallpaper.likes || 0}}</text>
        <text class="stat-item">👁️ {{wallpaper.views || 0}}</text>
        <text class="stat-item">💾 {{wallpaper.downloads || 0}}</text>
      </view>
    </view>

    <!-- 标签 -->
    <view class="tags" wx:if="{{wallpaper.tags && wallpaper.tags.length > 0}}">
      <text class="tag" wx:for="{{wallpaper.tags}}" wx:key="*this">{{item}}</text>
    </view>

    <!-- 分辨率 -->
    <view class="resolution" wx:if="{{wallpaper.width && wallpaper.height}}">
      <text class="res-text">分辨率：{{wallpaper.width}} × {{wallpaper.height}}</text>
    </view>
  </view>

  <!-- 操作按钮区 -->
  <view class="action-section">
    <!-- 收藏按钮 -->
    <view class="action-btn favorite-btn {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
      <text class="action-icon">{{isFavorited ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>

    <!-- 下载按钮（看激励视频后下载高清原图） -->
    <view class="action-btn download-btn" bindtap="downloadWallpaper">
      <text class="action-icon">📥</text>
      <text class="action-text">下载原图</text>
    </view>

    <!-- 分享按钮 -->
    <button class="action-btn share-btn" open-type="share">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="download-tip">
    <text>💡 点击"下载原图"观看一段小视频，即可免费保存高清壁纸</text>
  </view>

  <!-- 更多推荐 -->
  <view class="recommend-section" wx:if="{{recommendList.length > 0}}">
    <view class="recommend-title">
      <text class="title-line"></text>
      <text class="title-text">更多推荐</text>
      <text class="title-line"></text>
    </view>
    
    <view class="waterfall">
      <view class="waterfall-column">
        <block wx:for="{{leftRecommend}}" wx:key="_id">
          <view class="wallpaper-card" bindtap="goDetail" data-id="{{item._id}}">
            <image class="wallpaper-img" src="{{item.thumbUrl || item.url}}" mode="widthFix" lazy-load="{{true}}" style="height: {{item.displayHeight}}px;"></image>
          </view>
        </block>
      </view>
      <view class="waterfall-column">
        <block wx:for="{{rightRecommend}}" wx:key="_id">
          <view class="wallpaper-card" bindtap="goDetail" data-id="{{item._id}}">
            <image class="wallpaper-img" src="{{item.thumbUrl || item.url}}" mode="widthFix" lazy-load="{{true}}" style="height: {{item.displayHeight}}px;"></image>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-wrapper" wx:if="{{loading}}">
  <view class="loading-dot"></view>
  <view class="loading-dot"></view>
  <view class="loading-dot"></view>
</view>

<!-- 激励视频广告弹窗 -->
<view class="ad-modal" wx:if="{{showAdModal}}">
  <view class="ad-modal-mask" bindtap="closeAdModal"></view>
  <view class="ad-modal-content">
    <view class="ad-modal-header">
      <text class="ad-modal-title">🎬 免费下载高清原图</text>
      <text class="ad-modal-close" bindtap="closeAdModal">✕</text>
    </view>
    <view class="ad-modal-body">
      <text class="ad-modal-desc">观看一小段视频，即可免费保存高清原图到相册</text>
      <view class="ad-modal-buttons">
        <view class="ad-modal-btn watch-btn" bindtap="watchAdAndDownload">
          <text>▶️ 观看视频并下载</text>
        </view>
        <view class="ad-modal-btn cancel-btn" bindtap="closeAdModal">
          <text>暂不下载</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 下载中提示 -->
<view class="toast" wx:if="{{toastVisible}}">
  <text>{{toastText}}</text>
</view>
