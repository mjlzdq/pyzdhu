/* pages/detail/detail.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 图片预览 */
.image-wrapper {
  width: 100%;
  background: #000;
}

.preview-image {
  width: 100%;
  display: block;
}

/* 信息区 */
.info-section {
  padding: 24rpx 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #6c63ff;
  background: rgba(108, 99, 255, 0.15);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.info-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #888;
}

/* 标签 */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #aaa;
  background: rgba(255, 255, 255, 0.05);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 分辨率 */
.resolution {
  padding-top: 8rpx;
}

.res-text {
  font-size: 24rpx;
  color: #666;
}

/* 操作按钮 */
.action-section {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx 10rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 10rpx;
  border-radius: 20rpx;
  background: #1a1a2e;
  border: none;
  transition: all 0.2s;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #aaa;
}

.share-btn {
  padding: 24rpx 10rpx;
  line-height: 1.2;
}

.download-btn {
  background: linear-gradient(135deg, #6c63ff, #e94560);
}

.download-btn .action-text {
  color: #fff;
  font-weight: 600;
}

.favorite-btn.favorited {
  background: rgba(233, 69, 96, 0.15);
}

.favorite-btn.favorited .action-text {
  color: #e94560;
}

/* 下载提示 */
.download-tip {
  text-align: center;
  padding: 16rpx 40rpx 30rpx;
  color: #666;
  font-size: 22rpx;
}

/* 推荐区域 */
.recommend-section {
  padding: 10rpx 0 30rpx;
}

.recommend-title {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 30rpx 20rpx;
  gap: 20rpx;
}

.title-line {
  width: 60rpx;
  height: 2rpx;
  background: #2a2a4a;
}

.title-text {
  font-size: 28rpx;
  color: #888;
  font-weight: 600;
}

/* 瀑布流 */
.waterfall {
  display: flex;
  padding: 0 16rpx;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wallpaper-card {
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a2e;
}

.wallpaper-card:active {
  transform: scale(0.97);
}

.wallpaper-img {
  width: 100%;
  display: block;
  border-radius: 16rpx;
}

/* 广告弹窗 */
.ad-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ad-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.ad-modal-content {
  position: relative;
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx;
  z-index: 1;
}

.ad-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.ad-modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.ad-modal-close {
  font-size: 36rpx;
  color: #666;
  padding: 8rpx;
}

.ad-modal-body {
  text-align: center;
}

.ad-modal-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  display: block;
  margin-bottom: 36rpx;
}

.ad-modal-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ad-modal-btn {
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.watch-btn {
  background: linear-gradient(135deg, #6c63ff, #e94560);
  color: #fff;
}

.cancel-btn {
  background: transparent;
  color: #888;
  border: 2rpx solid #333;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.85);
  color: #fff;
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  z-index: 2000;
  animation: toastIn 0.3s ease;
}

@keyframes toastIn {
  from { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
  to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}
