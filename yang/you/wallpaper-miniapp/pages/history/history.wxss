/* pages/history/history.wxss */
.container {
  padding-bottom: 40rpx;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 30rpx;
}

.action-clear {
  font-size: 26rpx;
  color: #e94560;
  padding: 8rpx 20rpx;
}

.waterfall {
  display: flex;
  padding: 0 16rpx;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wallpaper-card {
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a2e;
}

.wallpaper-img {
  width: 100%;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
}

.wallpaper-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 16rpx;
}

.wallpaper-tag {
  font-size: 22rpx;
  color: #6c63ff;
  background: rgba(108, 99, 255, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.view-time {
  font-size: 20rpx;
  color: #666;
}

.empty-sub {
  font-size: 24rpx;
  color: #555;
  margin-top: 8rpx;
}
