<!-- pages/mine/mine.wxml -->
<view class="container">
  <!-- 用户头部 -->
  <view class="user-header">
    <view class="user-avatar">
      <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else class="avatar-placeholder">😊</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo && userInfo.nickName ? userInfo.nickName : '壁纸爱好者'}}</text>
      <text class="user-desc">用壁纸装点每一天 ✨</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-section">
    <view class="stat-item" bindtap="goFavorites">
      <text class="stat-num">{{favoriteCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goHistory">
      <text class="stat-num">{{historyCount}}</text>
      <text class="stat-label">浏览记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{downloadCount}}</text>
      <text class="stat-label">下载</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goFavorites">
      <view class="menu-left">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goHistory">
      <view class="menu-left">
        <text class="menu-icon">🕐</text>
        <text class="menu-text">浏览记录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">给个好评</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">📤</text>
        <text class="menu-text">分享给好友</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-text">用户协议</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私政策</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部文案 -->
  <view class="footer">
    <text class="footer-text">高清壁纸 v1.0.0</text>
  </view>
</view>
