/* pages/mine/mine.wxss */
.container {
  padding-bottom: 40rpx;
}

/* 用户头部 */
.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #1a1a2e, #0f0f23);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #6c63ff, #e94560);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #888;
}

/* 统计区域 */
.stats-section {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #1a1a2e;
  border-radius: 20rpx;
  margin: 24rpx;
  padding: 30rpx 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #6c63ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: #2a2a4a;
}

/* 菜单 */
.menu-section {
  background: #1a1a2e;
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #2a2a4a;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #ddd;
}

.menu-arrow {
  font-size: 36rpx;
  color: #555;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #555;
}
