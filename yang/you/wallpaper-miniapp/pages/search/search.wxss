/* pages/search/search.wxss */
.container {
  padding-bottom: 20rpx;
}

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 20rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #1a1a2e;
  border: 2rpx solid #2a2a4a;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.clear-btn {
  font-size: 28rpx;
  color: #666;
  padding: 4rpx 8rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #6c63ff;
  white-space: nowrap;
}

/* 搜索历史 */
.search-history {
  padding: 20rpx 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ccc;
}

.history-clear {
  font-size: 24rpx;
  color: #888;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  font-size: 26rpx;
  color: #aaa;
  background: #1a1a2e;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 热门搜索 */
.hot-search {
  padding: 20rpx 30rpx;
}

.hot-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ccc;
  margin-bottom: 20rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  font-size: 26rpx;
  color: #e94560;
  background: rgba(233, 69, 96, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 搜索结果 */
.search-results {
  padding: 0 10rpx;
}

.result-header {
  padding: 16rpx 20rpx;
}

.result-count {
  font-size: 24rpx;
  color: #666;
}

/* 瀑布流 */
.waterfall {
  display: flex;
  padding: 0 16rpx;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.wallpaper-card {
  border-radius: 16rpx;
  overflow: hidden;
  background: #1a1a2e;
}

.wallpaper-card:active {
  transform: scale(0.97);
}

.wallpaper-img {
  width: 100%;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
}

.wallpaper-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 16rpx;
}

.wallpaper-tag {
  font-size: 22rpx;
  color: #6c63ff;
  background: rgba(108, 99, 255, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.like-count {
  font-size: 22rpx;
  color: #888;
}

.load-more {
  text-align: center;
  padding: 40rpx;
  color: #555;
  font-size: 24rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #555;
  margin-top: 8rpx;
}
